# Copy to .env and fill in. The connector auto-loads connector/.env on `npm start`.
# These are the PUBLIC Firebase web config values (same project as the brain-cloud
# dashboard — Firebase Console → Project Settings → your Web app). Not secrets.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=          # e.g. your-project.firebaseapp.com
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=       # optional
FIREBASE_MESSAGING_SENDER_ID=  # optional
FIREBASE_APP_ID=               # optional

# Where per-user brain working copies live (STUB:STORE). Defaults to
# ~/.brain-connector/users. For a quick demo you can point a user dir here.
# CONNECTOR_BRAIN_BASE=/tmp/brain-connector-users

# PORT=8788
