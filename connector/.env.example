# Copy to .env and fill in. The connector auto-loads connector/.env on `npm start`.
# These are the PUBLIC Firebase web config values (same project as the brain-cloud
# dashboard — Firebase Console → Project Settings → your Web app). Not secrets.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=          # e.g. your-project.firebaseapp.com
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=       # optional
FIREBASE_MESSAGING_SENDER_ID=  # optional
FIREBASE_APP_ID=               # optional

# Where per-user brain working copies live. Defaults to ~/.brain-connector/users
# (in production the systemd unit sets this to /opt/brain-connector/users).
# CONNECTOR_BRAIN_BASE=/tmp/brain-connector-users

# PORT=8788
# Interface to bind. Defaults to 127.0.0.1 (reached via the local reverse proxy).
# CONNECTOR_BIND_HOST=127.0.0.1

# AUTH FAIL-CLOSED: with no FIREBASE_* set, /authorize will REFUSE to log anyone in
# unless you explicitly opt into the dev auto-approve stub below — and even then it
# is disabled whenever NODE_ENV=production. Leave this unset for any real instance.
# CONNECTOR_DEV_AUTH=1
